API_TOKEN=TELEGRAM_BOT_TOKEN
ADMINS=123456789,987654321
HMAC_SECRET_KEY=change-me

# Optional: HTTP/SOCKS proxy for api.telegram.org (needed if Telegram is blocked)
# On host: http://127.0.0.1:10808
# In Docker: http://host.docker.internal:10808  (default in docker-compose.yml)
# TELEGRAM_PROXY=http://host.docker.internal:10808

# Used by the app and docker-compose.yml (postgres + redis services)
DB_NAME=diplomathesis
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Dev seed (runs on startup if user does not exist yet)
# SEED_TELEGRAM_ID=466024868
